UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then Main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + (i.Position.X - dStart.X), sPos.Y.Scale, sPos.Y.Offset + (i.Position.Y - dStart.Y)) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)

table.insert(US.Connections, RunService.Heartbeat:Connect(function()
    UpdatePlayers()
    local ap = PlayerGui:FindFirstChild("AdminPanel")
    local p = ap and ap:FindFirstChild("AdminPanel")
    local sc = p and p:FindFirstChild("Content") and p.Content:FindFirstChild("ScrollingFrame")
    for c, d in pairs(CBtns) do
        local rb = sc and sc:FindFirstChild(c)
        if rb then
            local cd = rb:GetAttribute("OnCooldown")
            local t = rb:FindFirstChild("Timer") and rb.Timer.Text or ""
            local vis = rb:FindFirstChild("Timer") and rb.Timer.Visible
            if cd and t ~= "" and vis then
                d.btn.Text = t .. "s"
                d.btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                d.btn.TextColor3 = Color3.fromRGB(0, 0, 0)
                d.str.Color = Color3.fromRGB(255, 255, 255)
            else
                d.btn.Text = d.defText
                d.btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                d.btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                d.str.Color = Color3.fromRGB(80, 80, 80)
            end
        end
    end
end))

local ProximityAura = Instance.new("Part")
ProximityAura.Name = "ProximityAP"
ProximityAura.Anchored = true
ProximityAura.CanCollide = false
ProximityAura.CastShadow = false
ProximityAura.Material = Enum.Material.Neon
ProximityAura.Color = Color3.fromRGB(255, 255, 255)
ProximityAura.Transparency = 0.8
ProximityAura.Shape = Enum.PartType.Cylinder

table.insert(US.Connections, RunService.Heartbeat:Connect(function()
    local c = LocalPlayer.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if US.ProximityAP and hrp then
        ProximityAura.Parent = Workspace
        ProximityAura.Size = Vector3.new(0.1, US.ProximityRadius * 2, US.ProximityRadius * 2)
        ProximityAura.CFrame = hrp.CFrame * CFrame.Angles(0, 0, math.rad(90)) - Vector3.new(0, 2.5, 0)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude <= US.ProximityRadius then
                    local nw = tick()
                    if not US.LastTime[p.Name] or (nw - US.LastTime[p.Name] > 1.5) then
                        US.LastTime[p.Name] = nw
                        fireCycle(p)
                    end
                end
            end
        end
    else
        ProximityAura.Parent = nil
    end
end))

local HL = Instance.new("Highlight")
HL.FillColor = Color3.fromRGB(255, 255, 255)
HL.FillTransparency = 0.5
HL.OutlineColor = Color3.fromRGB(255, 255, 255)
local HTarget = nil

table.insert(US.Connections, RunService.RenderStepped:Connect(function()
    if not US.ClickToAP then HL.Parent = nil HTarget = nil return end
    local ray = Mouse.UnitRay
    local cl, bd = nil, 20
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos = p.Character.HumanoidRootPart.Position
            local v = pos - ray.Origin
            local proj = v:Dot(ray.Direction)
            if proj > 0 then
                local d = (v - ray.Direction * proj).Magnitude
                if d <= bd then bd = d cl = p end
            end
        end
    end
    if cl then HTarget = cl HL.Parent = cl.Character else HTarget = nil HL.Parent = nil end
end))

table.insert(US.Connections, UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if waitingForKey and i.UserInputType == Enum.UserInputType.Keyboard then
        local kn = i.KeyCode.Name
        if kn and kn ~= "Unknown" then
            US[waitingForKey] = kn
            keyButtons[waitingForKey].Text = kn
            SaveSettings()
        else
            keyButtons[waitingForKey].Text = US[waitingForKey]
        end
        waitingForKey = nil
        return
    end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = i.KeyCode.Name
        if k == US.RagdollKey then DoRagdoll()
        elseif k == US.RejoinKey then DoRejoin()
        elseif k == US.KickKey then DoKick()
        elseif k == US.ResetKey then DoReset() end
    end
    if i.UserInputType == Enum.UserInputType.MouseButton1 and US.ClickToAP and HTarget then
        fireCycle(HTarget)
    end
end))

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    US.IgnoreNextSteal = false
end)

function US.Disable()
    US.Running = false
    for _, c in pairs(US.Connections) do pcall(function() c:Disconnect() end) end
    US.Connections = {}
    SaveSettings()
    if Gui then Gui:Destroy() end
    if ProximityAura then ProximityAura:Destroy() end
    if HL then HL:Destroy() end
end
