    l.TextXAlignment = Enum.TextXAlignment.Left
    local sb = Instance.new("TextButton", h)
    sb.Size = UDim2.new(1, -20, 0, 6)
    sb.Position = UDim2.new(0, 10, 0, 28)
    sb.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    sb.Text = ""
    Instance.new("UICorner", sb).CornerRadius = UDim.new(1, 0)
    local f = Instance.new("Frame", sb)
    f.Size = UDim2.new((cur - min)/(max - min), 0, 1, 0)
    f.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    local d = false
    local function move(i)
        local pct = math.clamp((i.Position.X - sb.AbsolutePosition.X) / sb.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + ((max - min) * pct))
        f.Size = UDim2.new(pct, 0, 1, 0)
        l.Text = name .. ": " .. val
        cb(val)
    end
    sb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = true move(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
    UserInputService.InputChanged:Connect(function(i) if d and i.UserInputType == Enum.UserInputType.MouseMovement then move(i) end end)
end

