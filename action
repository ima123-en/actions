local function getTB()
    local ap = PlayerGui:FindFirstChild("AdminPanel")
    local p = ap and ap:FindFirstChild("AdminPanel")
    local cb = p and p:FindFirstChild("CommandBox")
    return cb and cb:FindFirstChild("TextBox")
end

local function exec(target, cmd)
    if not target or not cmd then return end
    local tb = getTB()
    if not tb then return end
    tb.Text = ";"..cmd.." "..target
    RunService.RenderStepped:Wait()
    if getconnections then for _,c in ipairs(getconnections(tb.FocusLost)) do c:Fire(true) end
    elseif firesignal then firesignal(tb.FocusLost, true) end
end

local function fireCycle(target)
    if not target then return end
    local n = target.Name
    US.Strikes[n] = (US.Strikes[n] or 0) + 1
    
    task.spawn(function()
        local strike = US.Strikes[n]
        if strike <= #Cycle then
            exec(n, Cycle[strike])
        else
            for _, c in ipairs(CmdList) do
                exec(n, c)
                task.wait(0.2)
            end
        end
    end)
end

