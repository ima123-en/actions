local AdminCommands = {}
local cmdList = {}

pcall(function()
    local Admin = ReplicatedStorage:WaitForChild("Datas"):WaitForChild("AdminCommands")
    for _, mod in ipairs(Admin:GetChildren()) do
        local data = require(mod)
        if data and type(data) == "table" then
            local cmdName = data.name or mod.Name
            AdminCommands[cmdName] = true
            if cmdName ~= "control" and cmdName ~= "nightvision" then
                table.insert(cmdList, cmdName)
            end
        end
    end
end)

local CYCLE_ORDER = {"Jail","Balloon","Ragdoll","Rocket","Inverse","Tiny","Jumpscare","Morph"}
local cycleCmds = {}
do
    for _, want in ipairs(CYCLE_ORDER) do
        local lw = want:lower()
        for name in pairs(AdminCommands) do
            if name:lower() == lw then
                table.insert(cycleCmds, name)
                break
            end
        end
    end
    if #cycleCmds == 0 then
        for _, name in ipairs(cmdList) do
            table.insert(cycleCmds, name)
        end
    end
end

local APIndex = {}

local function getTB()
    local ap = PlayerGui:FindFirstChild("AdminPanel")
    local p  = ap and ap:FindFirstChild("AdminPanel")
    local cb = p and p:FindFirstChild("CommandBox")
    return cb and cb:FindFirstChild("TextBox")
end

local function exec(target, cmd)
    if not target or not cmd then return end
    local tb = getTB()
    if not tb then return end
    tb.Text = ";" .. cmd .. " " .. target
    RunService.RenderStepped:Wait()
    if getconnections then
        for _, c in ipairs(getconnections(tb.FocusLost)) do c:Fire(true) end
    elseif firesignal then
        firesignal(tb.FocusLost, true)
    end
end

local function triggerOneCommand(target)
    if not target or #cycleCmds == 0 then return end
    local name = target.Name
    local idx = APIndex[name] or 1
    if idx < 1 or idx > #cycleCmds then idx = 1 end
    local cmd = cycleCmds[idx]
    exec(name, cmd)
    APIndex[name] = (idx % #cycleCmds) + 1
end

local function nearest()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local best, dist = nil, 999999
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < dist then dist = d best = p end
        end
    end
    return best
end

