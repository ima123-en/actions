local function CreateActionToggle(name, yPos, state, cb)
    local h = Instance.new("Frame", ActionPanel)
    h.Size = UDim2.new(0.9, 0, 0, 36)
    h.Position = UDim2.new(0.05, 0, 0, yPos)
    h.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Instance.new("UICorner", h).CornerRadius = UDim.new(0, 8)
    local l = Instance.new("TextLabel", h)
    l.Size = UDim2.new(0.65, 0, 1, 0)
    l.Position = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Text = name
    l.Font = Enum.Font.Gotham
    l.TextSize = 12
    l.TextColor3 = Color3.fromRGB(170, 170, 180)
    l.TextXAlignment = Enum.TextXAlignment.Left
    local bg = Instance.new("Frame", h)
    bg.Size = UDim2.new(0, 40, 0, 20)
    bg.Position = UDim2.new(1, -52, 0.5, -10)
    bg.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    bg.BorderSizePixel = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    local c = Instance.new("Frame", bg)
    c.Size = UDim2.new(0, 16, 0, 16)
    c.Position = UDim2.new(0, 2, 0.5, -8)
    c.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
    c.BorderSizePixel = 0
    Instance.new("UICorner", c).CornerRadius = UDim.new(1, 0)
    local b = Instance.new("TextButton", h)
    b.Size = UDim2.new(1, 0, 1, 0)
    b.BackgroundTransparency = 1
    b.Text = ""
    local function upd(a, inst)
        local pos = a and UDim2.new(0, 22, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        local bgc = a and Color3.fromRGB(255,255,255) or Color3.fromRGB(80,80,90)
        local mbgc = a and Color3.fromRGB(255,255,255) or Color3.fromRGB(35,35,40)
        local tc = a and Color3.fromRGB(255,255,255) or Color3.fromRGB(170,170,180)
        if inst then
            c.Position=pos c.BackgroundColor3=bgc bg.BackgroundColor3=mbgc l.TextColor3=tc
        else
            TweenService:Create(c, TweenInfo.new(0.2), {Position=pos, BackgroundColor3=bgc}):Play()
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3=mbgc}):Play()
            TweenService:Create(l, TweenInfo.new(0.2), {TextColor3=tc}):Play()
        end
    end
    upd(state, true)
    b.MouseButton1Click:Connect(function() state = not state upd(state, false) cb(state) end)
    return upd
end

