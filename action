local MIN_RADIUS, MAX_RADIUS = 5, 60
local sliderDragging = false

local function SetRadiusFromAlpha(alpha)
    alpha = math.clamp(alpha, 0, 1)
    local radius = math.floor(MIN_RADIUS + (MAX_RADIUS - MIN_RADIUS) * alpha)
    US.ProximityRadius = radius
    RadiusLabel.Text = "Radius: " .. tostring(radius)
    SliderFill.Size = UDim2.new(alpha, 0, 1, 0)
    SliderKnob.Position = UDim2.new(alpha, -6, 0.5, -6)
end

task.defer(function()
    local alpha = (US.ProximityRadius - MIN_RADIUS) / (MAX_RADIUS - MIN_RADIUS)
    SetRadiusFromAlpha(alpha)
end)

