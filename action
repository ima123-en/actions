local hoverTarget = nil
local HL = Instance.new("Highlight")
HL.FillColor = Color3.fromRGB(138, 43, 226)
HL.FillTransparency = 0.5
HL.OutlineColor = Color3.fromRGB(255, 255, 255)

RunService.RenderStepped:Connect(function()
    if not US.ClickToAP then
        HL.Parent = nil
        hoverTarget = nil
        return
    end

    local cam = Workspace.CurrentCamera
    if not cam then return end
    local ray = cam:ScreenPointToRay(Mouse.X, Mouse.Y)
    local bestP, bestDist = nil, 15

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos = p.Character.HumanoidRootPart.Position
            local v = pos - ray.Origin
            local proj = v:Dot(ray.Direction)
            if proj > 0 then
                local d = (v - ray.Direction * proj).Magnitude
                if d < bestDist then
                    bestDist = d
                    bestP = p
                end
            end
        end
    end

    if bestP and bestP.Character then
        hoverTarget = bestP
        HL.Parent = bestP.Character
    else
        hoverTarget = nil
        HL.Parent = nil
    end
end)

table.insert(US.Connections, UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if waitingForKey and i.UserInputType == Enum.UserInputType.Keyboard then
        local kn = i.KeyCode.Name
        if kn and kn ~= "Unknown" then
            US[waitingForKey] = kn
            keyButtons[waitingForKey].Text = kn
            SaveSettings()
        else
            keyButtons[waitingForKey].Text = US[waitingForKey]
        end
        waitingForKey = nil
        return
    end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = i.KeyCode.Name
        if k == US.RagdollKey then DoRagdoll()
        elseif k == US.RejoinKey then DoRejoin()
        elseif k == US.KickKey then DoKick()
        elseif k == US.ResetKey then DoReset() end
    elseif i.UserInputType == Enum.UserInputType.MouseButton1 then
        if US.ClickToAP and hoverTarget then
            triggerOneCommand(hoverTarget)
        end
    end
end))

