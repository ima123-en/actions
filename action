local function UpdatePlayers()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local isSel = (US.Selected == p.Name)
        local stealData = US.StealStatus[p.Name]
        local isStealing = stealData and stealData.expire > tick()
        
        if not PlayerFrames[p.Name] then
            local f = Instance.new("Frame", PList)
            f.Size = UDim2.new(1, -8, 0, 50)
            f.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
            local fs = Instance.new("UIStroke", f)
            fs.Thickness = 1
            
            local img = Instance.new("ImageLabel", f)
            img.Size = UDim2.new(0, 38, 0, 38)
            img.Position = UDim2.new(0, 6, 0, 6)
            img.Image = "rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=150&h=150"
            img.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)
            
            local n = Instance.new("TextLabel", f)
            n.Size = UDim2.new(1, -54, 0, 20)
            n.Position = UDim2.new(0, 50, 0, 4)
            n.BackgroundTransparency = 1
            n.Text = p.Name
            n.Font = Enum.Font.GothamBold
            n.TextSize = 11
            n.TextXAlignment = Enum.TextXAlignment.Left
            n.TextTruncate = Enum.TextTruncate.AtEnd
            
            local st = Instance.new("TextLabel", f)
            st.Size = UDim2.new(1, -54, 0, 18)
            st.Position = UDim2.new(0, 50, 0, 24)
            st.BackgroundTransparency = 1
            st.Text = ""
            st.Font = Enum.Font.Gotham
            st.TextSize = 10
            st.TextXAlignment = Enum.TextXAlignment.Left
            st.TextTruncate = Enum.TextTruncate.AtEnd
            
            local btn = Instance.new("TextButton", f)
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundTransparency = 1
            btn.Text = ""
            btn.MouseButton1Click:Connect(function() US.Selected = p.Name UpdatePlayers() end)
            
            PlayerFrames[p.Name] = {Frame = f, Stroke = fs, Name = n, Status = st}
        end
        
        local pf = PlayerFrames[p.Name]
        pf.Status.Text = isStealing and ("Steals: " .. stealData.item) or ""
        pf.Status.TextColor3 = isStealing and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(150, 150, 150)
        
        if isStealing then
            pf.Stroke.Color = Color3.fromRGB(255, 80, 80)
        elseif isSel then
            pf.Stroke.Color = Color3.fromRGB(255, 255, 255)
        else
            pf.Stroke.Color = Color3.fromRGB(50, 50, 50)
        end
        
        pf.Frame.BackgroundColor3 = isSel and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(20, 20, 20)
        pf.Name.TextColor3 = isSel and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
    end
end

