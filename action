local lastInside = {}
task.spawn(function()
    while US.Running do
        if US.ProximityAP then
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                        local inNow = d <= US.ProximityRadius
                        local wasIn = lastInside[p]
                        if inNow and not wasIn then triggerOneCommand(p) end
                        lastInside[p] = inNow
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

local circle
local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getGroundPos(origin)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ray = Workspace:Raycast(origin + Vector3.new(0, 5, 0), Vector3.new(0, -1000, 0), params)
    if ray then return Vector3.new(origin.X, ray.Position.Y + 0.05, origin.Z)
    else return origin - Vector3.new(0, 3, 0) end
end

RunService.RenderStepped:Connect(function()
    if not US.ProximityAP then
        if circle then circle.CFrame = CFrame.new(0, -9999, 0) end
        return
    end
    local hrp = getHRP()
    if not hrp then
        if circle then circle.CFrame = CFrame.new(0, -9999, 0) end
        return
    end
    local pos = getGroundPos(hrp.Position)
    if not circle then
        local p = Instance.new("Part")
        p.Name = "ProxCircle"
        p.Anchored = true
        p.CanCollide = false
        p.CanTouch = false
        p.CanQuery = false
        p.Material = Enum.Material.ForceField
        p.Color = Color3.fromRGB(0, 0, 0)
        p.Transparency = 0.25
        p.Shape = Enum.PartType.Cylinder
        p.Parent = Workspace
        circle = p
    end
    circle.Size = Vector3.new(0.3, US.ProximityRadius * 2, US.ProximityRadius * 2)
    circle.CFrame = CFrame.new(pos) * CFrame.Angles(0, 0, math.rad(90))
end)

local hoverTarget = nil
local HL = Instance.new("Highlight")
HL.FillColor = Color3.fromRGB(138, 43, 226)
HL.FillTransparency = 0.5
HL.OutlineColor = Color3.fromRGB(255, 255, 255)

RunService.RenderStepped:Connect(function()
    if not US.ClickToAP then
        HL.Parent = nil
        hoverTarget = nil
        return
    end
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local ray = cam:ScreenPointToRay(Mouse.X, Mouse.Y)
    local bestP, bestDist = nil, 15
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos = p.Character.HumanoidRootPart.Position
            local v = pos - ray.Origin
            local proj = v:Dot(ray.Direction)
            if proj > 0 then
                local d = (v - ray.Direction * proj).Magnitude
                if d < bestDist then bestDist = d bestP = p end
            end
        end
    end
    if bestP and bestP.Character then
        hoverTarget = bestP
        HL.Parent = bestP.Character
    else
        hoverTarget = nil
        HL.Parent = nil
    end
end)

