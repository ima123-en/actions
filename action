local function updatePlayerList()
    for _, c in ipairs(PLScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local idx = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            idx += 1

            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, ROW_HEIGHT)
            row.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
            row.BorderSizePixel = 0
            row.Parent = PLScroll

            local avatar = Instance.new("ImageLabel")
            avatar.Size = UDim2.new(0, 28, 0, 28)
            avatar.Position = UDim2.new(0, 6, 0.5, -14)
            avatar.BackgroundTransparency = 1
            avatar.Parent = row
            local ok, content = pcall(function()
                return Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
            end)
            if ok then avatar.Image = content end

            local nameContainer = Instance.new("Frame")
            nameContainer.Size = UDim2.new(0, 200, 1, 0)
            nameContainer.Position = UDim2.new(0, 40, 0, 0)
            nameContainer.BackgroundTransparency = 1
            nameContainer.Parent = row

            local display = Instance.new("TextLabel")
            display.Size = UDim2.new(1, 0, 0.6, 0)
            display.Position = UDim2.new(0, 0, 0, 3)
            display.BackgroundTransparency = 1
            display.Text = p.DisplayName
            display.Font = Enum.Font.GothamBold
            display.TextSize = 14
            display.TextXAlignment = Enum.TextXAlignment.Left
            display.TextColor3 = Color3.fromRGB(230, 230, 235)
            display.Parent = nameContainer

            local full = Instance.new("TextLabel")
            full.Size = UDim2.new(1, 0, 0.4, 0)
            full.Position = UDim2.new(0, 0, 0.6, -2)
            full.BackgroundTransparency = 1
            full.Text = "@" .. p.Name
            full.Font = Enum.Font.Gotham
            full.TextSize = 12
            full.TextXAlignment = Enum.TextXAlignment.Left
            full.TextColor3 = Color3.fromRGB(150, 150, 160)
            full.Parent = nameContainer

            local function makeIconButton(index, icon, cmdName)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(0, 24, 0, 24)
                local baseX = 250
                local step = 28
                b.Position = UDim2.new(0, baseX + index * step, 0.5, -12)
                b.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                b.BorderSizePixel = 0
                b.Text = icon
                b.Font = Enum.Font.Gotham
                b.TextSize = 16
                b.TextColor3 = Color3.fromRGB(255, 255, 255)
                b.Parent = row
                if not cmdName then
                    b.AutoButtonColor = false
                    b.TextColor3 = Color3.fromRGB(90, 90, 90)
                    return
                end
                b.MouseButton1Click:Connect(function()
                    exec(p.Name, cmdName)
                end)
            end

            makeIconButton(0, "🎈", CMD_BALLOON)
            makeIconButton(1, "🚀", CMD_ROCKET)
            makeIconButton(2, "🤸", CMD_RAGDOLL)
            makeIconButton(3, "🔒", CMD_JAIL)
        end
    end

    PLScroll.CanvasSize = UDim2.new(0, 0, 0, idx * (ROW_HEIGHT + PLLayout.Padding.Offset))
end

