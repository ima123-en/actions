table.insert(US.Connections, UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if waitingForKey and i.UserInputType == Enum.UserInputType.Keyboard then
        local kn = i.KeyCode.Name
        if kn and kn ~= "Unknown" then
            US[waitingForKey] = kn
            keyButtons[waitingForKey].Text = kn
            SaveSettings()
        else
            keyButtons[waitingForKey].Text = US[waitingForKey]
        end
        waitingForKey = nil
        return
    end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = i.KeyCode.Name
        if k == US.RagdollKey then DoRagdoll()
        elseif k == US.RejoinKey then DoRejoin()
        elseif k == US.KickKey then DoKick()
        elseif k == US.ResetKey then DoReset() end
    end
    -- Removed ClickToAP logic
end))

