local function DoReset()
    US.IgnoreNextSteal = true
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local origCFrame = hrp.CFrame
    local camCFrame  = Workspace.CurrentCamera.CFrame
    pcall(function()
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
        LocalPlayer.Character = nil
    end)
    task.spawn(function()
        local newChar = LocalPlayer.CharacterAdded:Wait()
        local newHRP  = newChar:WaitForChild("HumanoidRootPart", 5)
        if newHRP then newHRP.CFrame = origCFrame end
        Workspace.CurrentCamera.CFrame = camCFrame
        task.wait(3)
        US.IgnoreNextSteal = false
    end)
end

local function KickForSteal()
    if not US.KickAfterSteal or US.IgnoreNextSteal then return end
    LocalPlayer:Kick("Steal Complete - Auto Kick")
end

local function extractItem(txt, pattern)
    local l = txt:lower()
    local idx = l:find(pattern)
    if idx then
        local raw = txt:sub(idx + #pattern)
        return raw:gsub(" from you.*", ""):gsub("[!%.]", "")
    end
    return nil
end

local function CheckText(txt)
    if type(txt) ~= "string" or txt == "" then return end
    local l = string.lower(txt)
    if l:find("you stole") then KickForSteal() return end
    for _, word in ipairs(StealWords) do
        if l:find(word) then
            local item = extractItem(txt, "is stealing ") or extractItem(txt, "stole your ") or extractItem(txt, "stole ")
            if item then US.StealStatus[LocalPlayer.Name] = {expire = tick() + 5, item = item} end
            break
        end
    end
end

local function HookUI(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        CheckText(obj.Text)
        table.insert(US.Connections, obj:GetPropertyChangedSignal("Text"):Connect(function() CheckText(obj.Text) end))
    end
end

for _, g in ipairs(PlayerGui:GetChildren()) do
    for _, d in ipairs(g:GetDescendants()) do HookUI(d) end
    table.insert(US.Connections, g.DescendantAdded:Connect(HookUI))
end
